extensions:
    - phpstan/phpstan-doctrine

parameters:
    level: 6
    paths:
        - bin/
        - config/
        - public/
        - src/
        - tests/
    # This solves the "If condition is always true" for PHPDoc types
    treatPhpDocTypesAsCertain: false
    # This ignores the ID assignment issue if you don't have the extension yet
    checkMissingIterableValueType: false

# Doctrine configuration
doctrine:
    objectManagerLoader: tests/object-manager.php
