# .env.local
# This file should be copied to .env.local and customized for your local environment
# DO NOT commit this file to git

###> Database Configuration ###
# For MariaDB 10.4.32 (matching the provided pharmax.sql dump)
DATABASE_URL="mysql://root:@127.0.0.1:3306/pharmax?serverVersion=10.4.32-MariaDB&charset=utf8mb4"

# For MySQL 8.0+
# DATABASE_URL="mysql://root:@127.0.0.1:3306/pharmax?serverVersion=8.0.32&charset=utf8mb4"

# For PostgreSQL
# DATABASE_URL="postgresql://user:password@127.0.0.1:5432/pharmax"
###< Database Configuration ###

###> API Keys & Secrets ###
# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""

# Stripe
# STRIPE_PUBLIC_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Gemini AI
# GEMINI_API_KEY=""

# HuggingFace
# HUGGINGFACE_API_KEY=""
###< API Keys & Secrets ###

###> Ollama (Local LLM) ###
# OLLAMA_API_URL=http://localhost:11434
# OLLAMA_MODEL=mistral
###< Ollama ###

###> JWT Configuration ###
JWT_PUBLIC_KEY_FILE=config/jwt/public.pem
JWT_PASSPHRASE=""
###< JWT Configuration ###

###> 2FA Configuration ###
# Google Authenticator TOTP_ISSUER
TOTP_ISSUER=Pharmax
###< 2FA Configuration ###

###> Mercure (Real-time Updates) ###
# MERCURE_URL=https://example.com/.well-known/mercure
# MERCURE_PUBLIC_URL=https://example.com/.well-known/mercure
# MERCURE_JWT_SECRET=!ChangeThisMercureHubJWTSecretKey!
###< Mercure ###
