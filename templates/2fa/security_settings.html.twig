<!-- 2FA Security Settings Component -->
<!-- Can be included in user profile page with: {% include '2fa/security_settings.html.twig' %} -->

<div class="card border-0 shadow-sm mt-4">
    <div class="card-header bg-light border-bottom">
        <h5 class="mb-0">
            <i class="fas fa-shield-alt text-success"></i> Two-Factor Authentication
        </h5>
    </div>

    <div class="card-body">
        {% if app.user.isTwoFactorAuthenticationEnabled %}
            <!-- 2FA Enabled State -->
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle"></i>
                <strong>Success!</strong> Two-factor authentication is active on your account.
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>

            <div class="row mb-4">
                <div class="col-md-6">
                    <h6 class="text-dark mb-2">Status</h6>
                    <p class="mb-0">
                        <span class="badge bg-success">
                            <i class="fas fa-shield-alt"></i> Active
                        </span>
                    </p>
                </div>
                <div class="col-md-6">
                    <h6 class="text-dark mb-2">Type</h6>
                    <p class="mb-0">
                        <span class="badge bg-info">Google Authenticator</span>
                    </p>
                </div>
            </div>

            <div class="alert alert-warning" role="alert">
                <i class="fas fa-exclamation-triangle"></i>
                <strong>Important:</strong> Always keep your authenticator app installed. If you lose access to it, you may be locked out of your account.
            </div>

            <div class="d-flex gap-2">
                <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#disable2faModal">
                    <i class="fas fa-times"></i> Disable 2FA
                </button>
                <button type="button" class="btn btn-outline-primary" onclick="alert('This feature will be available soon')">
                    <i class="fas fa-key"></i> View Recovery Codes
                </button>
            </div>

            <!-- Disable 2FA Modal -->
            <div class="modal fade" id="disable2faModal" tabindex="-1" aria-labelledby="disable2faModalLabel" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header bg-danger text-white">
                            <h5 class="modal-title" id="disable2faModalLabel">
                                <i class="fas fa-exclamation-triangle"></i> Disable Two-Factor Authentication
                            </h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <p class="text-dark">
                                <strong>Are you sure you want to disable two-factor authentication?</strong>
                            </p>
                            <p class="text-muted">
                                Disabling 2FA will make your account less secure. You'll only need your password to log in.
                            </p>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <form method="POST" action="{{ path('app_2fa_disable') }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('disable_2fa') }}">
                                <button type="submit" class="btn btn-danger">
                                    <i class="fas fa-times-circle"></i> Disable 2FA
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

        {% else %}
            <!-- 2FA Disabled State -->
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-circle"></i>
                <strong>Security Alert!</strong> Two-factor authentication is not enabled on your account.
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>

            <p class="text-muted">
                Protect your account with two-factor authentication. In addition to your password, you'll need to enter a code from your authenticator app to log in.
            </p>

            <h6 class="text-dark mb-3">Benefits:</h6>
            <ul class="list-unstyled">
                <li><i class="fas fa-check text-success"></i> <strong>Extra Security</strong> - Even if someone has your password, they can't access your account without the code</li>
                <li><i class="fas fa-check text-success"></i> <strong>Protection</strong> - Prevents unauthorized access even if your password is compromised</li>
                <li><i class="fas fa-check text-success"></i> <strong>Easy to Use</strong> - Works with popular authenticator apps on any smartphone</li>
            </ul>

            <div class="mt-4">
                <a href="{{ path('app_2fa_setup') }}" class="btn btn-success">
                    <i class="fas fa-shield-alt"></i> Enable Two-Factor Authentication
                </a>
            </div>
        {% endif %}
    </div>
</div>
